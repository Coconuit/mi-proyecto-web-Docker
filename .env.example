# ============================================
# Variables de entorno para docker-compose
# ============================================
# Copia este archivo a `.env` y rellena los valores reales.
# El archivo .env NO debe subirse al repositorio.
# ============================================

# Contraseña del usuario "app" en Postgres
DB_PASSWORD=cambiame_por_una_password_segura

# Puerto del host por el que se publicará el proxy nginx
# (en el VPS suele ser 80; en local puedes usar 8080 para no chocar)
PUBLIC_PORT=8080
